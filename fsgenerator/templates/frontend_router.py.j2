def _format_error(exc: Exception, t) -> str:
    if isinstance(exc, IntegrityError):
        orig = str(exc.orig).lower()
        if "unique" in orig or "duplicate" in orig:
            return t("common.error_unique")
        if "foreign" in orig or "fk" in orig:
            return t("common.error_foreign")
        if "not null" in orig or "notnull" in orig:
            return t("common.error_notnull")
        if "check" in orig:
            return t("common.error_check")
        return t("common.error_integrity")
    return t("common.error_generic")


