    items = List{{ entity.class_name }}s(repo)()
    return templates.TemplateResponse(request, "{{ entity.name }}_list.html", {
        "items": items,
        "t": t,
        "languages": list(request.app.state.translations.keys()),
        "current_lang": lang,
    })


