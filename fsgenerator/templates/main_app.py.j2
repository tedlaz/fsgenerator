@app.get("/set-tenant/{tenant_id}")
def set_tenant(tenant_id: {{ id_type }}, request: Request):
    referer = request.headers.get("referer", "/")
    response = RedirectResponse(url=referer, status_code=303)
    response.set_cookie("tenant_id", str(tenant_id), httponly=True, samesite="lax")
    return response


@app.get("/clear-tenant")
def clear_tenant(request: Request):
    referer = request.headers.get("referer", "/")
    response = RedirectResponse(url=referer, status_code=303)
    response.delete_cookie("tenant_id")
    return response

{% endif %}

@app.get("/", response_class=HTMLResponse)
def home(request: Request):
    lang = request.cookies.get("lang", "en")
    t = make_t(app.state.translations, lang)
    return templates.TemplateResponse(request, "home.html", {
        "t": t,
        "languages": list(app.state.translations.keys()),
        "current_lang": lang,
        "current_user": getattr(request.state, "current_user", None),
    })
