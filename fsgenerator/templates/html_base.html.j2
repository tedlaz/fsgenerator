<!DOCTYPE html>
<html lang="{% raw %}{{ current_lang }}{% endraw %}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% raw %}{% block title %}{% endraw %}{{ app_name }}{% raw %}{% endblock %}{% endraw %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="/static/style.css" rel="stylesheet">
</head>
<body>
    <div class="app-layout">
        <nav class="sidebar">
            <a href="/" class="sidebar-brand">
                <span class="brand-icon">{{ app_name[0] | upper }}</span>
                {{ app_name }}
            </a>
            <hr>
            <ul class="nav">
{% for entity in entities %}
                <li class="nav-item">
                    <a class="nav-link" href="/{{ entity.name }}">{% raw %}{{ t("{% endraw %}{{ entity.name }}{% raw %}._label") }}{% endraw %}</a>
                </li>
{% endfor %}
            </ul>
            <div class="sidebar-footer">
                <hr>
                <div class="dropdown">
                    <button class="dropdown-toggle" type="button" onclick="this.parentElement.classList.toggle('open')">
                        {% raw %}{{ current_lang }}{% endraw %}
                    </button>
                    <ul class="dropdown-menu">
                        {% raw %}{% for lang in languages %}{% endraw %}
                        <li><a class="dropdown-item" href="/set-lang/{% raw %}{{ lang }}{% endraw %}">{% raw %}{{ lang }}{% endraw %}</a></li>
                        {% raw %}{% endfor %}{% endraw %}
                    </ul>
                </div>
            </div>
        </nav>
        <main class="main-content">
            {% raw %}{% block content %}{% endblock %}{% endraw %}
        </main>
    </div>
    <script>document.addEventListener('click',function(e){document.querySelectorAll('.dropdown.open').forEach(function(d){if(!d.contains(e.target))d.classList.remove('open')})});</script>
</body>
</html>
