<!DOCTYPE html>
<html lang="{% raw %}{{ current_lang }}{% endraw %}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% raw %}{% block title %}{% endraw %}{{ app_name }}{% raw %}{% endblock %}{% endraw %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="/static/style.css" rel="stylesheet">
</head>
<body>
    <div class="app-layout">
        <button class="sidebar-toggle" aria-label="Toggle menu" onclick="document.querySelector('.sidebar').classList.toggle('open')">&#9776;</button>
        <nav class="sidebar">
            <a href="/" class="sidebar-brand">
                <span class="brand-icon">{{ app_name[0] | upper }}</span>
                {{ app_name }}
            </a>
{% if tenant_name %}
            <div class="tenant-selector" style="padding:0.5rem 1rem">
                <select class="form-select" style="width:100%" onchange="if(this.value){window.location.href='/set-tenant/'+this.value}else{window.location.href='/clear-tenant'}">
                    <option value="">{% raw %}{{ t("common.all") }}{% endraw %} {% raw %}{{ t("{% endraw %}{{ tenant_name }}{% raw %}._label") }}{% endraw %}</option>
                    {% raw %}{% for tn in request.state.tenants %}{% endraw %}

                    <option value="{% raw %}{{ tn.id }}{% endraw %}" {% raw %}{% if request.state.current_tenant and request.state.current_tenant.id == tn.id %}selected{% endif %}{% endraw %}>{% raw %}{{ tn }}{% endraw %}</option>
                    {% raw %}{% endfor %}{% endraw %}

                </select>
            </div>
{% endif %}
            <hr>
            <ul class="nav">
{% for entity in entities %}
                <li class="nav-item">
                    <a class="nav-link" href="/{{ entity.name }}">{% raw %}{{ t("{% endraw %}{{ entity.name }}{% raw %}._label") }}{% endraw %}</a>
                </li>
{% endfor %}
                {% raw %}{% if current_user and current_user.is_admin %}{% endraw %}
                <li class="nav-item">
                    <a class="nav-link" href="/admin/users">{% raw %}{{ t("auth.user_management") }}{% endraw %}</a>
                </li>
                {% raw %}{% endif %}{% endraw %}
            </ul>
            <div class="sidebar-footer">
                <hr>
                {% raw %}{% if current_user %}{% endraw %}
                <div class="sidebar-user">
                    <span class="sidebar-user-email">{% raw %}{{ current_user.email }}{% endraw %}</span>
                    <div class="sidebar-user-links">
                        <a href="/change-password">{% raw %}{{ t("auth.change_password") }}{% endraw %}</a>
                        <a href="/logout">{% raw %}{{ t("auth.logout") }}{% endraw %}</a>
                    </div>
                </div>
                <hr>
                {% raw %}{% endif %}{% endraw %}
                <div class="dropdown">
                    <button class="dropdown-toggle" type="button" onclick="this.parentElement.classList.toggle('open')">
                        {% raw %}{{ current_lang }}{% endraw %}
                    </button>
                    <ul class="dropdown-menu">
                        {% raw %}{% for lang in languages %}{% endraw %}
                        <li><a class="dropdown-item" href="/set-lang/{% raw %}{{ lang }}{% endraw %}">{% raw %}{{ lang }}{% endraw %}</a></li>
                        {% raw %}{% endfor %}{% endraw %}
                    </ul>
                </div>
            </div>
        </nav>
        <div class="sidebar-overlay" onclick="document.querySelector('.sidebar').classList.remove('open')"></div>
        <main class="main-content">
            {% raw %}{% block content %}{% endblock %}{% endraw %}
        </main>
    </div>
    <script>document.addEventListener('click',function(e){document.querySelectorAll('.dropdown.open').forEach(function(d){if(!d.contains(e.target))d.classList.remove('open')});if(e.target.closest('.sidebar .nav-link'))document.querySelector('.sidebar').classList.remove('open')});</script>
</body>
</html>
