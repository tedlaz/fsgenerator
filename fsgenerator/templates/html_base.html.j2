<!DOCTYPE html>
<html lang="{% raw %}{{ current_lang }}{% endraw %}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% raw %}{% block title %}{% endraw %}{{ app_name }}{% raw %}{% endblock %}{% endraw %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .sidebar { min-height: 100vh; }
        .sidebar .nav-link { color: rgba(255,255,255,.75); }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background-color: rgba(255,255,255,.1); }
    </style>
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar d-flex flex-column flex-shrink-0 p-3 bg-dark" style="width: 220px;">
            <a href="/" class="text-white text-decoration-none fs-5 mb-3">{{ app_name }}</a>
            <hr class="text-secondary">
            <ul class="nav nav-pills flex-column">
{% for entity in entities %}
                <li class="nav-item">
                    <a class="nav-link" href="/{{ entity.name }}">{% raw %}{{ t("{% endraw %}{{ entity.name }}{% raw %}._label") }}{% endraw %}</a>
                </li>
{% endfor %}
            </ul>
            <hr class="text-secondary mt-auto">
            <div class="dropdown">
                <button class="btn btn-outline-light dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                    {% raw %}{{ current_lang }}{% endraw %}
                </button>
                <ul class="dropdown-menu">
                    {% raw %}{% for lang in languages %}{% endraw %}
                    <li><a class="dropdown-item" href="/set-lang/{% raw %}{{ lang }}{% endraw %}">{% raw %}{{ lang }}{% endraw %}</a></li>
                    {% raw %}{% endfor %}{% endraw %}
                </ul>
            </div>
        </nav>
        <main class="flex-grow-1 p-4">
            {% raw %}{% block content %}{% endblock %}{% endraw %}
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
