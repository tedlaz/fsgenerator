{%- raw %}{% extends "base.html" %}

{% block title %}{% endraw %}{% raw %}{% if item and item.id %}{{ t("common.edit") }}{% else %}{{ t("common.new") }}{% endif %} {{ t("{% endraw %}{{ entity.name }}{% raw %}._label") }}{% endraw %}{% raw %}{% endblock %}

{% block content %}{% endraw %}
<h1>{% raw %}{% if item and item.id %}{{ t("common.edit") }}{% else %}{{ t("common.new") }}{% endif %} {{ t("{% endraw %}{{ entity.name }}{% raw %}._label") }}{% endraw %}</h1>
{% raw %}{% if error %}{% endraw %}
<div class="alert alert-danger">
    {% raw %}{{ error }}{% endraw %}
    <button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>
</div>
{% raw %}{% endif %}{% endraw %}
<div class="form-card">
<form method="post">
{% for rel in entity.relations if rel.type in ("many_to_one", "one_to_one") %}
{% if tenant_fk_field and rel.field_name == tenant_fk_field %}
    {% raw %}{% if request.state.current_tenant %}{% endraw %}

    <input type="hidden" name="{{ rel.field_name }}_id" value="{% raw %}{{ request.state.current_tenant.id }}{% endraw %}">
    {% raw %}{% else %}{% endraw %}

    <div class="form-group">
        <label for="{{ rel.field_name }}_id" class="form-label">{% raw %}{{ t("{% endraw %}{{ entity.name }}.{{ rel.field_name }}{% raw %}") }}{% endraw %}</label>
        <select class="form-select" id="{{ rel.field_name }}_id" name="{{ rel.field_name }}_id">
            <option value="">{% raw %}{{ t("common.select") }}{% endraw %}</option>
            {% raw %}{% for opt in {% endraw %}{{ rel.field_name }}_options{% raw %} %}{% endraw %}

            <option value="{% raw %}{{ opt.id }}{% endraw %}" {% raw %}{% if item and item.{% endraw %}{{ rel.field_name }}_id{% raw %} | string == opt.id | string %}selected{% endif %}{% endraw %}>{% raw %}{{ opt }}{% endraw %}</option>
            {% raw %}{% endfor %}{% endraw %}

        </select>
    </div>
    {% raw %}{% endif %}{% endraw %}

{% else %}
    <div class="form-group">
        <label for="{{ rel.field_name }}_id" class="form-label">{% raw %}{{ t("{% endraw %}{{ entity.name }}.{{ rel.field_name }}{% raw %}") }}{% endraw %}</label>
        <select class="form-select" id="{{ rel.field_name }}_id" name="{{ rel.field_name }}_id">
            <option value="">{% raw %}{{ t("common.select") }}{% endraw %}</option>
            {% raw %}{% for opt in {% endraw %}{{ rel.field_name }}_options{% raw %} %}{% endraw %}

            <option value="{% raw %}{{ opt.id }}{% endraw %}" {% raw %}{% if item and item.{% endraw %}{{ rel.field_name }}_id{% raw %} | string == opt.id | string %}selected{% endif %}{% endraw %}>{% raw %}{{ opt }}{% endraw %}</option>
            {% raw %}{% endfor %}{% endraw %}

        </select>
    </div>
{% endif %}
{% endfor %}
{% for field in entity.fields %}
    <div class="form-group">
        <label for="{{ field.name }}" class="form-label">{% raw %}{{ t("{% endraw %}{{ entity.name }}.{{ field.name }}{% raw %}") }}{% endraw %}</label>
{% if field.type == "select" and field.options %}
        <select class="form-select" id="{{ field.name }}" name="{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
            <option value="">{% raw %}{{ t("common.select") }}{% endraw %}</option>
{% for opt_value, opt_label in field.options %}
            <option value="{{ opt_value }}" {% raw %}{% if item and item.{% endraw %}{{ field.name }}{% raw %} | string == "{% endraw %}{{ opt_value }}{% raw %}" %}selected{% endif %}{% endraw %}>{{ opt_label }}</option>
{% endfor %}
        </select>
{% elif field.type in ("iso_date",) %}
        <input type="date" class="form-control" id="{{ field.name }}" name="{{ field.name }}"
               value="{% raw %}{{ item.{% endraw %}{{ field.name }}{% raw %} if item else '' }}{% endraw %}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("iso_datetime",) %}
        <input type="datetime-local" class="form-control" id="{{ field.name }}" name="{{ field.name }}"
               value="{% raw %}{{ item.{% endraw %}{{ field.name }}{% raw %} if item else '' }}{% endraw %}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("time",) %}
        <input type="time" class="form-control" id="{{ field.name }}" name="{{ field.name }}"
               value="{% raw %}{{ item.{% endraw %}{{ field.name }}{% raw %} if item else '' }}{% endraw %}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("integer", "value", "float", "percent") %}
        <input type="number" class="form-control" id="{{ field.name }}" name="{{ field.name }}"
               value="{% raw %}{{ item.{% endraw %}{{ field.name }}{% raw %} if item else '' }}{% endraw %}"{{ ' required' if not field.is_null else '' }}{{ ' step="0.01"' if field.type in ("value", "percent") else '' }}>
{% elif field.type == "string_numeric" %}
        <input type="text" class="form-control" id="{{ field.name }}" name="{{ field.name }}"
               pattern="\d+" value="{% raw %}{{ item.{% endraw %}{{ field.name }}{% raw %} if item else '' }}{% endraw %}"{{ ' required' if not field.is_null else '' }}{{ ' maxlength="%d"' % (field.length or field.max_length) if (field.length or field.max_length) else '' }}{{ ' minlength="%d"' % field.length if field.length else '' }}>
{% else %}
        <input type="text" class="form-control" id="{{ field.name }}" name="{{ field.name }}"
               value="{% raw %}{{ item.{% endraw %}{{ field.name }}{% raw %} if item else '' }}{% endraw %}"{{ ' required' if not field.is_null else '' }}{{ ' maxlength="%d"' % (field.length or field.max_length) if (field.length or field.max_length) else '' }}{{ ' minlength="%d"' % field.length if field.length else '' }}>
{% endif %}
    </div>
{% endfor %}
    <div class="form-actions">
        <button type="submit" class="btn btn-primary">{% raw %}{{ t("common.save") }}{% endraw %}</button>
        <a href="/{{ entity.name }}" class="btn btn-secondary">{% raw %}{{ t("common.cancel") }}{% endraw %}</a>
    </div>
</form>
</div>
{% if subform_entity %}
{% raw %}{% if item and item.id %}{% endraw %}
<hr>
<div class="toolbar">
    <h2 style="margin-bottom:0">{% raw %}{{ t("{% endraw %}{{ subform_entity.name }}{% raw %}._label") }}{% endraw %}</h2>
</div>
{% raw %}{% if subform_error %}{% endraw %}
<div class="alert alert-danger">
    {% raw %}{{ subform_error }}{% endraw %}
    <button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>
</div>
{% raw %}{% endif %}{% endraw %}
<div class="table-wrapper">
<table class="table">
    <thead>
        <tr>
{% for rel in subform_entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.target_entity != entity.name %}
            <th>{% raw %}{{ t("{% endraw %}{{ subform_entity.name }}.{{ rel.field_name }}{% raw %}") }}{% endraw %}</th>
{% endfor %}
{% for field in subform_entity.fields %}
            <th>{% raw %}{{ t("{% endraw %}{{ subform_entity.name }}.{{ field.name }}{% raw %}") }}{% endraw %}</th>
{% endfor %}
            <th>{% raw %}{{ t("common.actions") }}{% endraw %}</th>
        </tr>
    </thead>
    <tbody>
        {% raw %}{% for detail in subform_items %}{% endraw %}

        <tr
{% for rel in subform_entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.target_entity != entity.name %}
            data-{{ rel.field_name }}_id="{% raw %}{{ detail.{% endraw %}{{ rel.field_name }}_id{% raw %} }}{% endraw %}"
{% endfor %}
{% for field in subform_entity.fields %}
            data-{{ field.name }}="{% raw %}{{ detail.{% endraw %}{{ field.name }}{% raw %} }}{% endraw %}"
{% endfor %}
            data-id="{% raw %}{{ detail.id }}{% endraw %}"
        >
{% for rel in subform_entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.target_entity != entity.name %}
            <td>{% raw %}{{ detail.{% endraw %}{{ rel.field_name }}{% raw %} }}{% endraw %}</td>
{% endfor %}
{% for field in subform_entity.fields %}
            <td>{% raw %}{{ detail.{% endraw %}{{ field.name }}{% raw %} }}{% endraw %}</td>
{% endfor %}
            <td>
                <div class="actions">
                    <button type="button" class="btn btn-sm btn-warning" onclick="openSubEditModal(this.closest('tr'))">{% raw %}{{ t("common.edit") }}{% endraw %}</button>
{% if grandchild_entity %}
                    <button type="button" class="btn btn-sm btn-success" onclick="openFormGcAddModal('{% raw %}{{ detail.id }}{% endraw %}')">{% raw %}{{ t("common.add_child") }}{% endraw %}</button>
{% endif %}
                    <form class="delete-form" method="post" action="/{{ entity.name }}/{% raw %}{{ item.id }}{% endraw %}/{{ subform_entity.name }}/{% raw %}{{ detail.id }}{% endraw %}/delete" style="display:inline">
                        <button type="submit" class="btn btn-sm btn-danger">{% raw %}{{ t("common.delete") }}{% endraw %}</button>
                    </form>
                </div>
            </td>
        </tr>
        {% raw %}{% endfor %}{% endraw %}

    </tbody>
</table>
</div>
<div class="form-card" style="text-align:right">
    <button type="button" class="btn btn-success" onclick="openFormSubAddModal()">{% raw %}{{ t("common.add_new") }}{% endraw %} {% raw %}{{ t("{% endraw %}{{ subform_entity.name }}{% raw %}._label") }}{% endraw %}</button>
</div>
{% raw %}{% endif %}{% endraw %}
<!-- Subform edit modal -->
<div id="formSubModal" class="modal-overlay">
    <div class="modal-box">
        <h3>{% raw %}{{ t("common.edit") }}{% endraw %} {% raw %}{{ t("{% endraw %}{{ subform_entity.name }}{% raw %}._label") }}{% endraw %}</h3>
        <form id="formSubModalForm" method="post">
{% for rel in subform_entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.target_entity != entity.name %}
            <div class="form-group">
                <label class="form-label">{% raw %}{{ t("{% endraw %}{{ subform_entity.name }}.{{ rel.field_name }}{% raw %}") }}{% endraw %}</label>
                <select class="form-select" name="{{ rel.field_name }}_id" id="fsub_{{ rel.field_name }}_id">
                    <option value="">{% raw %}{{ t("common.select") }}{% endraw %}</option>
                    {% raw %}{% for opt in subform_{% endraw %}{{ rel.field_name }}{% raw %}_options %}{% endraw %}

                    <option value="{% raw %}{{ opt.id }}{% endraw %}">{% raw %}{{ opt }}{% endraw %}</option>
                    {% raw %}{% endfor %}{% endraw %}

                </select>
            </div>
{% endfor %}
{% for field in subform_entity.fields %}
            <div class="form-group">
                <label class="form-label">{% raw %}{{ t("{% endraw %}{{ subform_entity.name }}.{{ field.name }}{% raw %}") }}{% endraw %}</label>
{% if field.type in ("iso_date",) %}
                <input type="date" class="form-control" name="{{ field.name }}" id="fsub_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("iso_datetime",) %}
                <input type="datetime-local" class="form-control" name="{{ field.name }}" id="fsub_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("time",) %}
                <input type="time" class="form-control" name="{{ field.name }}" id="fsub_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("value", "percent", "float") %}
                <input type="number" class="form-control" name="{{ field.name }}" id="fsub_{{ field.name }}" step="0.01"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("integer",) %}
                <input type="number" class="form-control" name="{{ field.name }}" id="fsub_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type == "select" and field.options %}
                <select class="form-select" name="{{ field.name }}" id="fsub_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
                    <option value="">{% raw %}{{ t("common.select") }}{% endraw %}</option>
{% for opt_value, opt_label in field.options %}
                    <option value="{{ opt_value }}">{{ opt_label }}</option>
{% endfor %}
                </select>
{% else %}
                <input type="text" class="form-control" name="{{ field.name }}" id="fsub_{{ field.name }}"{{ ' required' if not field.is_null else '' }}{{ ' maxlength="%d"' % (field.length or field.max_length) if (field.length or field.max_length) else '' }}>
{% endif %}
            </div>
{% endfor %}
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeSubEditModal()">{% raw %}{{ t("common.cancel") }}{% endraw %}</button>
                <button type="submit" class="btn btn-primary">{% raw %}{{ t("common.save") }}{% endraw %}</button>
            </div>
        </form>
    </div>
</div>
<!-- Subform add modal -->
<div id="formSubAddModal" class="modal-overlay">
    <div class="modal-box">
        <h3>{% raw %}{{ t("common.add_new") }}{% endraw %} {% raw %}{{ t("{% endraw %}{{ subform_entity.name }}{% raw %}._label") }}{% endraw %}</h3>
        <form id="formSubAddModalForm" method="post" action="/{{ entity.name }}/{% raw %}{{ item.id }}{% endraw %}/{{ subform_entity.name }}/add">
{% for rel in subform_entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.target_entity != entity.name %}
            <div class="form-group">
                <label class="form-label">{% raw %}{{ t("{% endraw %}{{ subform_entity.name }}.{{ rel.field_name }}{% raw %}") }}{% endraw %}</label>
                <select class="form-select" name="{{ rel.field_name }}_id">
                    <option value="">{% raw %}{{ t("common.select") }}{% endraw %}</option>
                    {% raw %}{% for opt in subform_{% endraw %}{{ rel.field_name }}{% raw %}_options %}{% endraw %}

                    <option value="{% raw %}{{ opt.id }}{% endraw %}">{% raw %}{{ opt }}{% endraw %}</option>
                    {% raw %}{% endfor %}{% endraw %}

                </select>
            </div>
{% endfor %}
{% for field in subform_entity.fields %}
            <div class="form-group">
                <label class="form-label">{% raw %}{{ t("{% endraw %}{{ subform_entity.name }}.{{ field.name }}{% raw %}") }}{% endraw %}</label>
{% if field.type in ("iso_date",) %}
                <input type="date" class="form-control" name="{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("iso_datetime",) %}
                <input type="datetime-local" class="form-control" name="{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("time",) %}
                <input type="time" class="form-control" name="{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("value", "percent", "float") %}
                <input type="number" class="form-control" name="{{ field.name }}" step="0.01"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("integer",) %}
                <input type="number" class="form-control" name="{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type == "string_numeric" %}
                <input type="text" class="form-control" name="{{ field.name }}" pattern="\d+"{{ ' required' if not field.is_null else '' }}{{ ' maxlength="%d"' % (field.length or field.max_length) if (field.length or field.max_length) else '' }}>
{% elif field.type == "select" and field.options %}
                <select class="form-select" name="{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
                    <option value="">{% raw %}{{ t("common.select") }}{% endraw %}</option>
{% for opt_value, opt_label in field.options %}
                    <option value="{{ opt_value }}">{{ opt_label }}</option>
{% endfor %}
                </select>
{% else %}
                <input type="text" class="form-control" name="{{ field.name }}"{{ ' required' if not field.is_null else '' }}{{ ' maxlength="%d"' % (field.length or field.max_length) if (field.length or field.max_length) else '' }}>
{% endif %}
            </div>
{% endfor %}
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeFormSubAddModal()">{% raw %}{{ t("common.cancel") }}{% endraw %}</button>
                <button type="submit" class="btn btn-primary">{% raw %}{{ t("common.save") }}{% endraw %}</button>
            </div>
        </form>
    </div>
</div>
{% if grandchild_entity %}
<!-- Grandchild add modal -->
<div id="formGcAddModal" class="modal-overlay">
    <div class="modal-box">
        <h3>{% raw %}{{ t("common.add_new") }}{% endraw %} {% raw %}{{ t("{% endraw %}{{ grandchild_entity.name }}{% raw %}._label") }}{% endraw %}</h3>
        <form id="formGcAddModalForm" method="post">
            <input type="hidden" name="return_url" value="/{{ entity.name }}/{% raw %}{{ item.id }}{% endraw %}/edit">
{% for rel in grandchild_entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.target_entity != subform_entity.name %}
            <div class="form-group">
                <label class="form-label">{% raw %}{{ t("{% endraw %}{{ grandchild_entity.name }}.{{ rel.field_name }}{% raw %}") }}{% endraw %}</label>
                <select class="form-select" name="{{ rel.field_name }}_id" id="fgc_add_{{ rel.field_name }}_id">
                    <option value="">{% raw %}{{ t("common.select") }}{% endraw %}</option>
                    {% raw %}{% for opt in grandchild_{% endraw %}{{ rel.field_name }}{% raw %}_options %}{% endraw %}

                    <option value="{% raw %}{{ opt.id }}{% endraw %}">{% raw %}{{ opt }}{% endraw %}</option>
                    {% raw %}{% endfor %}{% endraw %}

                </select>
            </div>
{% endfor %}
{% for field in grandchild_entity.fields %}
            <div class="form-group">
                <label class="form-label">{% raw %}{{ t("{% endraw %}{{ grandchild_entity.name }}.{{ field.name }}{% raw %}") }}{% endraw %}</label>
{% if field.type in ("iso_date",) %}
                <input type="date" class="form-control" name="{{ field.name }}" id="fgc_add_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("iso_datetime",) %}
                <input type="datetime-local" class="form-control" name="{{ field.name }}" id="fgc_add_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("time",) %}
                <input type="time" class="form-control" name="{{ field.name }}" id="fgc_add_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("value", "percent", "float") %}
                <input type="number" class="form-control" name="{{ field.name }}" id="fgc_add_{{ field.name }}" step="0.01"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("integer",) %}
                <input type="number" class="form-control" name="{{ field.name }}" id="fgc_add_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type == "select" and field.options %}
                <select class="form-select" name="{{ field.name }}" id="fgc_add_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
                    <option value="">{% raw %}{{ t("common.select") }}{% endraw %}</option>
{% for opt_value, opt_label in field.options %}
                    <option value="{{ opt_value }}">{{ opt_label }}</option>
{% endfor %}
                </select>
{% else %}
                <input type="text" class="form-control" name="{{ field.name }}" id="fgc_add_{{ field.name }}"{{ ' required' if not field.is_null else '' }}{{ ' maxlength="%d"' % (field.length or field.max_length) if (field.length or field.max_length) else '' }}>
{% endif %}
            </div>
{% endfor %}
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeFormGcAddModal()">{% raw %}{{ t("common.cancel") }}{% endraw %}</button>
                <button type="submit" class="btn btn-primary">{% raw %}{{ t("common.save") }}{% endraw %}</button>
            </div>
        </form>
    </div>
</div>
{% endif %}
<script>
function openSubEditModal(row) {
    var d = row.dataset;
    var form = document.getElementById('formSubModalForm');
    form.action = '/{{ entity.name }}/{% raw %}{{ item.id }}{% endraw %}/{{ subform_entity.name }}/' + d.id + '/update';
{% for rel in subform_entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.target_entity != entity.name %}
    document.getElementById('fsub_{{ rel.field_name }}_id').value = d.{{ rel.field_name }}_id || '';
{% endfor %}
{% for field in subform_entity.fields %}
    document.getElementById('fsub_{{ field.name }}').value = d.{{ field.name }} || '';
{% endfor %}
    document.getElementById('formSubModal').classList.add('open');
}
function closeSubEditModal() {
    document.getElementById('formSubModal').classList.remove('open');
}
function openFormSubAddModal() {
    document.getElementById('formSubAddModalForm').reset();
    document.getElementById('formSubAddModal').classList.add('open');
}
function closeFormSubAddModal() {
    document.getElementById('formSubAddModal').classList.remove('open');
}
{% if grandchild_entity %}
function openFormGcAddModal(parentId) {
    var form = document.getElementById('formGcAddModalForm');
    form.action = '/{{ subform_entity.name }}/' + parentId + '/{{ grandchild_entity.name }}/add';
    form.reset();
    document.getElementById('formGcAddModal').classList.add('open');
}
function closeFormGcAddModal() {
    document.getElementById('formGcAddModal').classList.remove('open');
}
{% endif %}
</script>
{% endif %}
{% raw %}{% endblock %}{% endraw %}
