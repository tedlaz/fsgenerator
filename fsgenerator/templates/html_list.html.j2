<script>
/* ── Column visibility ─────────────────────────────── */
var _colKey = '{{ entity.name }}_cols';
var _colState = JSON.parse(localStorage.getItem(_colKey) || '{}');

/* Build set of columns that are hidden by default (not in representation) */
var _colDefaults = {};
document.querySelectorAll('[data-col-default="hidden"]').forEach(function(el) {
    _colDefaults[el.getAttribute('data-col')] = false;
});

function _isColVisible(col) {
    if (col in _colState) return _colState[col];
    if (col in _colDefaults) return false;
    return true;
}

function _applyColVisibility() {
    document.querySelectorAll('[data-col]').forEach(function(el) {
        var col = el.getAttribute('data-col');
        el.style.display = _isColVisible(col) ? '' : 'none';
    });
    document.querySelectorAll('[data-col-toggle]').forEach(function(cb) {
        var col = cb.getAttribute('data-col-toggle');
        cb.checked = _isColVisible(col);
    });
}
_applyColVisibility();

document.querySelectorAll('[data-col-toggle]').forEach(function(cb) {
    cb.addEventListener('change', function() {
        var col = this.getAttribute('data-col-toggle');
        _colState[col] = this.checked;
        localStorage.setItem(_colKey, JSON.stringify(_colState));
        _applyColVisibility();
    });
});

function openColModal() {
    document.getElementById('colModal').classList.add('open');
}
function closeColModal() {
    document.getElementById('colModal').classList.remove('open');
}

function openMainModal(row) {
    var d = row.dataset;
    var form = document.getElementById('mainModalForm');
    form.action = '/{{ entity.name }}/' + d.id + '/edit';
{% for rel in entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.field_name != tenant_fk_field %}
    document.getElementById('main_{{ rel.field_name }}_id').value = d.{{ rel.field_name }}_id || '';
{% endfor %}
{% for field in entity.fields %}
    document.getElementById('main_{{ field.name }}').value = d.{{ field.name }} || '';
{% endfor %}
    document.getElementById('mainModal').classList.add('open');
}
function closeMainModal() {
    document.getElementById('mainModal').classList.remove('open');
}
function openMainAddModal() {
    document.getElementById('mainAddModalForm').reset();
    document.getElementById('mainAddModal').classList.add('open');
}
function closeMainAddModal() {
    document.getElementById('mainAddModal').classList.remove('open');
}
function openViewModal(row) {
    var d = row.dataset;
{% for rel in entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.field_name != tenant_fk_field %}
    var sel_{{ rel.field_name }} = document.getElementById('main_{{ rel.field_name }}_id');
    var opt_{{ rel.field_name }} = sel_{{ rel.field_name }}.querySelector('option[value="' + (d.{{ rel.field_name }}_id || '') + '"]');
    document.getElementById('view_{{ rel.field_name }}').textContent = opt_{{ rel.field_name }} ? opt_{{ rel.field_name }}.textContent : (d.{{ rel.field_name }}_id || '');
{% endfor %}
{% for field in entity.fields %}
{% if field.type == "select" and field.options %}
    var selF_{{ field.name }} = document.getElementById('main_{{ field.name }}');
    var optF_{{ field.name }} = selF_{{ field.name }}.querySelector('option[value="' + (d.{{ field.name }} || '') + '"]');
    document.getElementById('view_{{ field.name }}').textContent = optF_{{ field.name }} ? optF_{{ field.name }}.textContent : (d.{{ field.name }} || '');
{% else %}
    document.getElementById('view_{{ field.name }}').textContent = d.{{ field.name }} || '';
{% endif %}
{% endfor %}
    document.getElementById('viewModal').classList.add('open');
}
function closeViewModal() {
    document.getElementById('viewModal').classList.remove('open');
}
{% if subform_entity %}
var _accKey = '{{ entity.name }}_acc';
var _accState = JSON.parse(sessionStorage.getItem(_accKey) || '{}');

function _saveAccState() { sessionStorage.setItem(_accKey, JSON.stringify(_accState)); }

function _getRowId(row) {
    return row.dataset.id || row.querySelector('.badge') && row.querySelector('.badge').textContent.trim() || '';
}

function _openRow(parentRow) {
    var detail = parentRow.nextElementSibling;
    var chevron = parentRow.querySelector('.accordion-chevron');
    detail.style.display = '';
    chevron.innerHTML = '&#9660;';
    parentRow.classList.add('accordion-open');
}

function _closeRow(parentRow) {
    var detail = parentRow.nextElementSibling;
    var chevron = parentRow.querySelector('.accordion-chevron');
    detail.style.display = 'none';
    chevron.innerHTML = '&#9654;';
    parentRow.classList.remove('accordion-open');
}

function toggleAccordion(parentRow) {
    if (event.target.closest('a, button, form')) return;
    var rid = _getRowId(parentRow);
    var detail = parentRow.nextElementSibling;
    if (detail.style.display === 'none') {
        _openRow(parentRow);
        _accState['p_' + rid] = true;
    } else {
        _closeRow(parentRow);
        delete _accState['p_' + rid];
    }
    _saveAccState();
}
{% if grandchild_entity %}
function toggleNestedAccordion(row) {
    if (event.target.closest('a, button, form')) return;
    event.stopPropagation();
    var rid = row.dataset.id || '';
    var detail = row.nextElementSibling;
    if (detail.style.display === 'none') {
        _openRow(row);
        _accState['c_' + rid] = true;
    } else {
        _closeRow(row);
        delete _accState['c_' + rid];
    }
    _saveAccState();
}
{% endif %}

/* Restore accordion state on page load */
(function() {
    document.querySelectorAll('tr.accordion-parent').forEach(function(row) {
        var rid = _getRowId(row);
        var isNested = row.closest('.accordion-detail') !== null;
        var key = isNested ? 'c_' + rid : 'p_' + rid;
        if (_accState[key]) _openRow(row);
    });
})();
