{%- raw %}{% extends "base.html" %}

{% block title %}{% endraw %}{% raw %}{{ t("{% endraw %}{{ entity.name }}{% raw %}._label") }}{% endraw %}{% raw %}{% endblock %}

{% block content %}{% endraw %}
{% raw %}{% if error %}{% endraw %}
<div class="alert alert-danger">
    {% raw %}{{ error }}{% endraw %}
    <button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>
</div>
{% raw %}{% endif %}{% endraw %}
<div class="toolbar">
    <h1 style="margin-bottom:0">{% raw %}{{ t("{% endraw %}{{ entity.name }}{% raw %}._label") }}{% endraw %}</h1>
    <div class="toolbar-actions">
        <button type="button" class="btn btn-outline" onclick="openColModal()">&#9881; {% raw %}{{ t("common.columns") }}{% endraw %}</button>
        <button type="button" class="btn btn-success" onclick="openMainAddModal()">{% raw %}{{ t("common.add_new") }}{% endraw %}</button>
    </div>
</div>
<div class="table-wrapper">
<table class="table">
    <thead>
        <tr>
{% if subform_entity %}
            <th style="width:2rem"></th>
{% endif %}
            <th data-col="id">{% raw %}{{ t("common.id") }}{% endraw %}</th>
{% for rel in entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.field_name != tenant_fk_field %}
            <th data-col="{{ rel.field_name }}"{{ ' data-col-default="hidden"' if rel.field_name not in entity.representation else '' }}>{% raw %}{{ t("{% endraw %}{{ entity.name }}.{{ rel.field_name }}{% raw %}") }}{% endraw %}</th>
{% endfor %}
{% for field in entity.fields %}
            <th data-col="{{ field.name }}"{{ ' data-col-default="hidden"' if field.name not in entity.representation else '' }}>{% raw %}{{ t("{% endraw %}{{ entity.name }}.{{ field.name }}{% raw %}") }}{% endraw %}</th>
{% endfor %}
            <th data-col="_actions">{% raw %}{{ t("common.actions") }}{% endraw %}</th>
        </tr>
    </thead>
    <tbody>
        {% raw %}{% for item in items %}{% endraw %}

        <tr{% if subform_entity %} class="accordion-parent" onclick="toggleAccordion(this)"{% endif %}
{% for rel in entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.field_name != tenant_fk_field %}
            data-{{ rel.field_name }}_id="{% raw %}{{ item.{% endraw %}{{ rel.field_name }}_id{% raw %} }}{% endraw %}"
{% endfor %}
{% for field in entity.fields %}
            data-{{ field.name }}="{% raw %}{{ item.{% endraw %}{{ field.name }}{% raw %} }}{% endraw %}"
{% endfor %}
            data-id="{% raw %}{{ item.id }}{% endraw %}"
        >
{% if subform_entity %}
            <td class="accordion-chevron">&#9654;</td>
{% endif %}
            <td data-col="id"><span class="badge">{% raw %}{{ item.id }}{% endraw %}</span></td>
{% for rel in entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.field_name != tenant_fk_field %}
            <td data-col="{{ rel.field_name }}">{% raw %}{{ item.{% endraw %}{{ rel.field_name }}{% raw %} }}{% endraw %}</td>
{% endfor %}
{% for field in entity.fields %}
{% if field.type == "select" and field.options %}
            <td data-col="{{ field.name }}">{% raw %}{{ {% endraw %}{{ '{' }}{% for opt_value, opt_label in field.options %}{{ opt_value }}: "{{ opt_label }}"{{ ", " if not loop.last else "" }}{% endfor %}{{ '}' }}{% raw %}.get(item.{% endraw %}{{ field.name }}{% raw %}, item.{% endraw %}{{ field.name }}{% raw %}) }}{% endraw %}</td>
{% else %}
            <td data-col="{{ field.name }}">{% raw %}{{ item.{% endraw %}{{ field.name }}{% raw %} }}{% endraw %}</td>
{% endif %}
{% endfor %}
            <td data-col="_actions">
                <div class="actions">
                    <button type="button" class="btn btn-sm btn-secondary" onclick="event.stopPropagation();openViewModal(this.closest('tr'))">{% raw %}{{ t("common.view") }}{% endraw %}</button>
                    <button type="button" class="btn btn-sm btn-warning" onclick="event.stopPropagation();openMainModal(this.closest('tr'))">{% raw %}{{ t("common.edit") }}{% endraw %}</button>
{% if subform_entity %}
                    <button type="button" class="btn btn-sm btn-success" onclick="event.stopPropagation();openSubAddModal('{% raw %}{{ item.id }}{% endraw %}')">{% raw %}{{ t("common.add_child") }}{% endraw %}</button>
{% endif %}
                    <form class="delete-form" method="post" action="/{{ entity.name }}/{% raw %}{{ item.id }}{% endraw %}/delete">
                        <button type="submit" class="btn btn-sm btn-danger">{% raw %}{{ t("common.delete") }}{% endraw %}</button>
                    </form>
                </div>
            </td>
        </tr>
{% if subform_entity %}
        <tr class="accordion-detail" style="display:none">
            <td colspan="{{ 2 + entity.relations|selectattr('type','in',['many_to_one','one_to_one'])|list|length + entity.fields|length + (1 if subform_entity else 0) }}">
                {% raw %}{% if subform_items[item.id] %}{% endraw %}

                <table class="table subform-table">
                    <thead>
                        <tr>
{% if grandchild_entity %}
                            <th style="width:2rem"></th>
{% endif %}
{% for rel in subform_entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.target_entity != entity.name %}
                            <th>{% raw %}{{ t("{% endraw %}{{ subform_entity.name }}.{{ rel.field_name }}{% raw %}") }}{% endraw %}</th>
{% endfor %}
{% for field in subform_entity.fields %}
                            <th>{% raw %}{{ t("{% endraw %}{{ subform_entity.name }}.{{ field.name }}{% raw %}") }}{% endraw %}</th>
{% endfor %}
                            <th>{% raw %}{{ t("common.actions") }}{% endraw %}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% raw %}{% for detail in subform_items[item.id] %}{% endraw %}

                        <tr{% if grandchild_entity %} class="accordion-parent" onclick="toggleNestedAccordion(this)"{% endif %}
{% for rel in subform_entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.target_entity != entity.name %}
                            data-{{ rel.field_name }}_id="{% raw %}{{ detail.{% endraw %}{{ rel.field_name }}_id{% raw %} }}{% endraw %}"
{% endfor %}
{% for field in subform_entity.fields %}
                            data-{{ field.name }}="{% raw %}{{ detail.{% endraw %}{{ field.name }}{% raw %} }}{% endraw %}"
{% endfor %}
                            data-id="{% raw %}{{ detail.id }}{% endraw %}"
                            data-parent-id="{% raw %}{{ item.id }}{% endraw %}"
                        >
{% if grandchild_entity %}
                            <td class="accordion-chevron">&#9654;</td>
{% endif %}
{% for rel in subform_entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.target_entity != entity.name %}
                            <td>{% raw %}{{ detail.{% endraw %}{{ rel.field_name }}{% raw %} }}{% endraw %}</td>
{% endfor %}
{% for field in subform_entity.fields %}
                            <td>{% raw %}{{ detail.{% endraw %}{{ field.name }}{% raw %} }}{% endraw %}</td>
{% endfor %}
                            <td>
                                <div class="actions">
                                    <button type="button" class="btn btn-sm btn-warning" onclick="event.stopPropagation();openSubModal(this.closest('tr'))">{% raw %}{{ t("common.edit") }}{% endraw %}</button>
{% if grandchild_entity %}
                                    <button type="button" class="btn btn-sm btn-success" onclick="event.stopPropagation();openGcAddModal('{% raw %}{{ detail.id }}{% endraw %}')">{% raw %}{{ t("common.add_child") }}{% endraw %}</button>
{% endif %}
                                    <form class="delete-form" method="post" action="/{{ entity.name }}/{% raw %}{{ item.id }}{% endraw %}/{{ subform_entity.name }}/{% raw %}{{ detail.id }}{% endraw %}/delete" style="display:inline">
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="event.stopPropagation()">{% raw %}{{ t("common.delete") }}{% endraw %}</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
{% if grandchild_entity %}
                        <tr class="accordion-detail" style="display:none">
                            <td colspan="{{ (2 + subform_entity.relations|selectattr('type','in',['many_to_one','one_to_one'])|rejectattr('target_entity','equalto',entity.name)|list|length + subform_entity.fields|length) }}">
                                {% raw %}{% if grandchild_items[detail.id] %}{% endraw %}

                                <table class="table subform-table">
                                    <thead>
                                        <tr>
{% for rel in grandchild_entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.target_entity != subform_entity.name %}
                                            <th>{% raw %}{{ t("{% endraw %}{{ grandchild_entity.name }}.{{ rel.field_name }}{% raw %}") }}{% endraw %}</th>
{% endfor %}
{% for field in grandchild_entity.fields %}
                                            <th>{% raw %}{{ t("{% endraw %}{{ grandchild_entity.name }}.{{ field.name }}{% raw %}") }}{% endraw %}</th>
{% endfor %}
                                            <th>{% raw %}{{ t("common.actions") }}{% endraw %}</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% raw %}{% for gc in grandchild_items[detail.id] %}{% endraw %}

                                        <tr
{% for rel in grandchild_entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.target_entity != subform_entity.name %}
                                            data-{{ rel.field_name }}_id="{% raw %}{{ gc.{% endraw %}{{ rel.field_name }}_id{% raw %} }}{% endraw %}"
{% endfor %}
{% for field in grandchild_entity.fields %}
                                            data-{{ field.name }}="{% raw %}{{ gc.{% endraw %}{{ field.name }}{% raw %} }}{% endraw %}"
{% endfor %}
                                            data-id="{% raw %}{{ gc.id }}{% endraw %}"
                                            data-parent-id="{% raw %}{{ detail.id }}{% endraw %}"
                                        >
{% for rel in grandchild_entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.target_entity != subform_entity.name %}
                                            <td>{% raw %}{{ gc.{% endraw %}{{ rel.field_name }}{% raw %} }}{% endraw %}</td>
{% endfor %}
{% for field in grandchild_entity.fields %}
                                            <td>{% raw %}{{ gc.{% endraw %}{{ field.name }}{% raw %} }}{% endraw %}</td>
{% endfor %}
                                            <td>
                                                <div class="actions">
                                                    <button type="button" class="btn btn-sm btn-warning" onclick="openGcModal(this.closest('tr'))">{% raw %}{{ t("common.edit") }}{% endraw %}</button>
                                                    <form class="delete-form" method="post" action="/{{ subform_entity.name }}/{% raw %}{{ detail.id }}{% endraw %}/{{ grandchild_entity.name }}/{% raw %}{{ gc.id }}{% endraw %}/delete" style="display:inline">
                                                        <button type="submit" class="btn btn-sm btn-danger">{% raw %}{{ t("common.delete") }}{% endraw %}</button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                        {% raw %}{% endfor %}{% endraw %}

                                    </tbody>
                                </table>
                                {% raw %}{% else %}{% endraw %}

                                <p class="text-muted" style="margin:0.5rem 0;font-style:italic">{% raw %}{{ t("common.no_records") }}{% endraw %}</p>
                                {% raw %}{% endif %}{% endraw %}

                            </td>
                        </tr>
{% endif %}
                        {% raw %}{% endfor %}{% endraw %}

                    </tbody>
                </table>
                {% raw %}{% else %}{% endraw %}

                <p class="text-muted" style="margin:0.5rem 0;font-style:italic">{% raw %}{{ t("common.no_records") }}{% endraw %}</p>
                {% raw %}{% endif %}{% endraw %}

            </td>
        </tr>
{% endif %}
        {% raw %}{% endfor %}{% endraw %}

    </tbody>
</table>
</div>
<!-- Column visibility modal -->
<div id="colModal" class="modal-overlay">
    <div class="modal-box col-modal-box">
        <h3>{% raw %}{{ t("common.columns") }}{% endraw %}</h3>
        <div class="col-check-list">
            <label class="col-check-item">
                <input type="checkbox" data-col-toggle="id" checked>
                <span>{% raw %}{{ t("common.id") }}{% endraw %}</span>
            </label>
{% for rel in entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.field_name != tenant_fk_field %}
            <label class="col-check-item">
                <input type="checkbox" data-col-toggle="{{ rel.field_name }}"{{ ' checked' if rel.field_name in entity.representation else '' }}>
                <span>{% raw %}{{ t("{% endraw %}{{ entity.name }}.{{ rel.field_name }}{% raw %}") }}{% endraw %}</span>
            </label>
{% endfor %}
{% for field in entity.fields %}
            <label class="col-check-item">
                <input type="checkbox" data-col-toggle="{{ field.name }}"{{ ' checked' if field.name in entity.representation else '' }}>
                <span>{% raw %}{{ t("{% endraw %}{{ entity.name }}.{{ field.name }}{% raw %}") }}{% endraw %}</span>
            </label>
{% endfor %}
            <label class="col-check-item">
                <input type="checkbox" data-col-toggle="_actions" checked>
                <span>{% raw %}{{ t("common.actions") }}{% endraw %}</span>
            </label>
        </div>
        <div class="modal-actions">
            <button type="button" class="btn btn-secondary" onclick="closeColModal()">{% raw %}{{ t("common.close") }}{% endraw %}</button>
        </div>
    </div>
</div>
<!-- Main entity edit modal -->
<div id="mainModal" class="modal-overlay">
    <div class="modal-box">
        <h3>{% raw %}{{ t("common.edit") }}{% endraw %} {% raw %}{{ t("{% endraw %}{{ entity.name }}{% raw %}._label") }}{% endraw %}</h3>
        <form id="mainModalForm" method="post">
            <input type="hidden" name="return_url" value="/{{ entity.name }}">
{% for rel in entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.field_name != tenant_fk_field %}
            <div class="form-group">
                <label class="form-label">{% raw %}{{ t("{% endraw %}{{ entity.name }}.{{ rel.field_name }}{% raw %}") }}{% endraw %}</label>
                <select class="form-select" name="{{ rel.field_name }}_id" id="main_{{ rel.field_name }}_id">
                    <option value="">{% raw %}{{ t("common.select") }}{% endraw %}</option>
                    {% raw %}{% for opt in {% endraw %}{{ rel.field_name }}{% raw %}_options %}{% endraw %}

                    <option value="{% raw %}{{ opt.id }}{% endraw %}">{% raw %}{{ opt }}{% endraw %}</option>
                    {% raw %}{% endfor %}{% endraw %}

                </select>
            </div>
{% endfor %}
{% for field in entity.fields %}
            <div class="form-group">
                <label class="form-label">{% raw %}{{ t("{% endraw %}{{ entity.name }}.{{ field.name }}{% raw %}") }}{% endraw %}</label>
{% if field.type in ("iso_date",) %}
                <input type="date" class="form-control" name="{{ field.name }}" id="main_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("iso_datetime",) %}
                <input type="datetime-local" class="form-control" name="{{ field.name }}" id="main_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("time",) %}
                <input type="time" class="form-control" name="{{ field.name }}" id="main_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("value", "percent", "float") %}
                <input type="number" class="form-control" name="{{ field.name }}" id="main_{{ field.name }}" step="0.01"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("integer",) %}
                <input type="number" class="form-control" name="{{ field.name }}" id="main_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type == "select" and field.options %}
                <select class="form-select" name="{{ field.name }}" id="main_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
                    <option value="">{% raw %}{{ t("common.select") }}{% endraw %}</option>
{% for opt_value, opt_label in field.options %}
                    <option value="{{ opt_value }}">{{ opt_label }}</option>
{% endfor %}
                </select>
{% elif field.type == "string_numeric" %}
                <input type="text" class="form-control" name="{{ field.name }}" id="main_{{ field.name }}" pattern="\d+"{{ ' required' if not field.is_null else '' }}{{ ' maxlength="%d"' % (field.length or field.max_length) if (field.length or field.max_length) else '' }}>
{% else %}
                <input type="text" class="form-control" name="{{ field.name }}" id="main_{{ field.name }}"{{ ' required' if not field.is_null else '' }}{{ ' maxlength="%d"' % (field.length or field.max_length) if (field.length or field.max_length) else '' }}>
{% endif %}
            </div>
{% endfor %}
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeMainModal()">{% raw %}{{ t("common.cancel") }}{% endraw %}</button>
                <button type="submit" class="btn btn-primary">{% raw %}{{ t("common.save") }}{% endraw %}</button>
            </div>
        </form>
    </div>
</div>
<!-- View detail modal -->
<div id="viewModal" class="modal-overlay">
    <div class="modal-box">
        <h3>{% raw %}{{ t("common.view") }}{% endraw %} {% raw %}{{ t("{% endraw %}{{ entity.name }}{% raw %}._label") }}{% endraw %}</h3>
{% for rel in entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.field_name != tenant_fk_field %}
        <div class="form-group">
            <label class="form-label">{% raw %}{{ t("{% endraw %}{{ entity.name }}.{{ rel.field_name }}{% raw %}") }}{% endraw %}</label>
            <div class="form-control" id="view_{{ rel.field_name }}" style="background:#f5f5f5;pointer-events:none"></div>
        </div>
{% endfor %}
{% for field in entity.fields %}
        <div class="form-group">
            <label class="form-label">{% raw %}{{ t("{% endraw %}{{ entity.name }}.{{ field.name }}{% raw %}") }}{% endraw %}</label>
            <div class="form-control" id="view_{{ field.name }}" style="background:#f5f5f5;pointer-events:none"></div>
        </div>
{% endfor %}
        <div class="modal-actions">
            <button type="button" class="btn btn-secondary" onclick="closeViewModal()">{% raw %}{{ t("common.close") }}{% endraw %}</button>
        </div>
    </div>
</div>
<!-- Main entity add modal -->
<div id="mainAddModal" class="modal-overlay">
    <div class="modal-box">
        <h3>{% raw %}{{ t("common.add_new") }}{% endraw %} {% raw %}{{ t("{% endraw %}{{ entity.name }}{% raw %}._label") }}{% endraw %}</h3>
        <form id="mainAddModalForm" method="post" action="/{{ entity.name }}/new">
            <input type="hidden" name="return_url" value="/{{ entity.name }}">
{% for rel in entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.field_name != tenant_fk_field %}
            <div class="form-group">
                <label class="form-label">{% raw %}{{ t("{% endraw %}{{ entity.name }}.{{ rel.field_name }}{% raw %}") }}{% endraw %}</label>
                <select class="form-select" name="{{ rel.field_name }}_id">
                    <option value="">{% raw %}{{ t("common.select") }}{% endraw %}</option>
                    {% raw %}{% for opt in {% endraw %}{{ rel.field_name }}{% raw %}_options %}{% endraw %}

                    <option value="{% raw %}{{ opt.id }}{% endraw %}">{% raw %}{{ opt }}{% endraw %}</option>
                    {% raw %}{% endfor %}{% endraw %}

                </select>
            </div>
{% endfor %}
{% for field in entity.fields %}
            <div class="form-group">
                <label class="form-label">{% raw %}{{ t("{% endraw %}{{ entity.name }}.{{ field.name }}{% raw %}") }}{% endraw %}</label>
{% if field.type in ("iso_date",) %}
                <input type="date" class="form-control" name="{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("iso_datetime",) %}
                <input type="datetime-local" class="form-control" name="{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("time",) %}
                <input type="time" class="form-control" name="{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("value", "percent", "float") %}
                <input type="number" class="form-control" name="{{ field.name }}" step="0.01"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("integer",) %}
                <input type="number" class="form-control" name="{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type == "select" and field.options %}
                <select class="form-select" name="{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
                    <option value="">{% raw %}{{ t("common.select") }}{% endraw %}</option>
{% for opt_value, opt_label in field.options %}
                    <option value="{{ opt_value }}">{{ opt_label }}</option>
{% endfor %}
                </select>
{% elif field.type == "string_numeric" %}
                <input type="text" class="form-control" name="{{ field.name }}" pattern="\d+"{{ ' required' if not field.is_null else '' }}{{ ' maxlength="%d"' % (field.length or field.max_length) if (field.length or field.max_length) else '' }}>
{% else %}
                <input type="text" class="form-control" name="{{ field.name }}"{{ ' required' if not field.is_null else '' }}{{ ' maxlength="%d"' % (field.length or field.max_length) if (field.length or field.max_length) else '' }}>
{% endif %}
            </div>
{% endfor %}
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeMainAddModal()">{% raw %}{{ t("common.cancel") }}{% endraw %}</button>
                <button type="submit" class="btn btn-primary">{% raw %}{{ t("common.save") }}{% endraw %}</button>
            </div>
        </form>
    </div>
</div>
{% if subform_entity %}
<!-- Subform edit modal -->
<div id="subModal" class="modal-overlay">
    <div class="modal-box">
        <h3>{% raw %}{{ t("common.edit") }}{% endraw %} {% raw %}{{ t("{% endraw %}{{ subform_entity.name }}{% raw %}._label") }}{% endraw %}</h3>
        <form id="subModalForm" method="post">
            <input type="hidden" name="return_url" value="/{{ entity.name }}">
{% for rel in subform_entity.relations if rel.type in ("many_to_one", "one_to_one") and rel.target_entity != entity.name %}
            <div class="form-group">
                <label class="form-label">{% raw %}{{ t("{% endraw %}{{ subform_entity.name }}.{{ rel.field_name }}{% raw %}") }}{% endraw %}</label>
                <select class="form-select" name="{{ rel.field_name }}_id" id="sub_{{ rel.field_name }}_id">
                    <option value="">{% raw %}{{ t("common.select") }}{% endraw %}</option>
                    {% raw %}{% for opt in subform_{% endraw %}{{ rel.field_name }}{% raw %}_options %}{% endraw %}

                    <option value="{% raw %}{{ opt.id }}{% endraw %}">{% raw %}{{ opt }}{% endraw %}</option>
                    {% raw %}{% endfor %}{% endraw %}

                </select>
            </div>
{% endfor %}
{% for field in subform_entity.fields %}
            <div class="form-group">
                <label class="form-label">{% raw %}{{ t("{% endraw %}{{ subform_entity.name }}.{{ field.name }}{% raw %}") }}{% endraw %}</label>
{% if field.type in ("iso_date",) %}
                <input type="date" class="form-control" name="{{ field.name }}" id="sub_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("iso_datetime",) %}
                <input type="datetime-local" class="form-control" name="{{ field.name }}" id="sub_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("time",) %}
                <input type="time" class="form-control" name="{{ field.name }}" id="sub_{{ field.name }}"{{ ' required' if not field.is_null else '' }}>
{% elif field.type in ("value", "percent", "float") %}
