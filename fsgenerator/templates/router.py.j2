from fastapi import APIRouter, Depends, HTTPException
from fastapi.security import HTTPAuthorizationCredentials, HTTPBearer
from sqlalchemy.orm import Session

from application.dtos.{{ entity.name }} import (
    {{ entity.class_name }}Create,
    {{ entity.class_name }}Response,
    {{ entity.class_name }}Update,
)
from application.use_cases.{{ entity.name }} import (
    Create{{ entity.class_name }},
    Delete{{ entity.class_name }},
    Get{{ entity.class_name }},
    List{{ entity.class_name }}s,
{% if has_tenant_filter %}
    List{{ entity.class_name }}sByTenant,
{% endif %}
    Update{{ entity.class_name }},
)
from auth_security import decode_access_token, get_current_user_or_none
from domain.entities.{{ entity.name }} import {{ entity.class_name }}
from infrastructure.persistence.sqlalchemy.repositories.{{ entity.name }} import (
    SQLAlchemy{{ entity.class_name }}Repository,
)
from infrastructure.web.fastapi.dependencies import get_session

router = APIRouter(prefix="/{{ entity.name }}", tags=["{{ entity.name }}"])
_bearer = HTTPBearer()


def _require_auth(
    credentials: HTTPAuthorizationCredentials = Depends(_bearer),
    session: Session = Depends(get_session),
):
    user = get_current_user_or_none(session, credentials.credentials)
    if not user or not user.is_active:
        raise HTTPException(status_code=401, detail="Invalid or expired token")
    return user
{% if is_tenant_entity %}


def _require_admin(
    credentials: HTTPAuthorizationCredentials = Depends(_bearer),
    session: Session = Depends(get_session),
):
    user = get_current_user_or_none(session, credentials.credentials)
    if not user or not user.is_active:
        raise HTTPException(status_code=401, detail="Invalid or expired token")
    if not user.is_admin:
        raise HTTPException(status_code=403, detail="Admin access required")
    return user
{% endif %}


@router.get("/", response_model=list[{{ entity.class_name }}Response])
{% if has_tenant_filter %}
def list_{{ entity.name }}s(tenant_id: {{ id_type }} | None = None, session: Session = Depends(get_session), _user=Depends(_require_auth)):
    repo = SQLAlchemy{{ entity.class_name }}Repository(session)
    if tenant_id is not None:
        return List{{ entity.class_name }}sByTenant(repo)(tenant_id)
    return List{{ entity.class_name }}s(repo)()
{% else %}
def list_{{ entity.name }}s(session: Session = Depends(get_session), _user=Depends(_require_auth)):
    repo = SQLAlchemy{{ entity.class_name }}Repository(session)
    use_case = List{{ entity.class_name }}s(repo)
    return use_case()
{% endif %}


@router.get("/{{ '{' }}{{ entity.name }}_id{{ '}' }}", response_model={{ entity.class_name }}Response)
def get_{{ entity.name }}({{ entity.name }}_id: {{ id_type }}, session: Session = Depends(get_session), _user=Depends(_require_auth)):
    repo = SQLAlchemy{{ entity.class_name }}Repository(session)
    use_case = Get{{ entity.class_name }}(repo)
    result = use_case({{ entity.name }}_id)
    if result is None:
        raise HTTPException(status_code=404, detail="{{ entity.class_name }} not found")
    return result


@router.post("/", response_model={{ entity.class_name }}Response, status_code=201)
def create_{{ entity.name }}(data: {{ entity.class_name }}Create, session: Session = Depends(get_session), _user=Depends({% if is_tenant_entity %}_require_admin{% else %}_require_auth{% endif %})):
    repo = SQLAlchemy{{ entity.class_name }}Repository(session)
    use_case = Create{{ entity.class_name }}(repo)
    entity = {{ entity.class_name }}(**data.model_dump())
    result = use_case(entity)
    session.commit()
    return result


@router.put("/{{ '{' }}{{ entity.name }}_id{{ '}' }}", response_model={{ entity.class_name }}Response)
def update_{{ entity.name }}({{ entity.name }}_id: {{ id_type }}, data: {{ entity.class_name }}Update, session: Session = Depends(get_session), _user=Depends({% if is_tenant_entity %}_require_admin{% else %}_require_auth{% endif %})):
    repo = SQLAlchemy{{ entity.class_name }}Repository(session)
    use_case = Update{{ entity.class_name }}(repo)
    result = use_case({{ entity.name }}_id, data.model_dump(exclude_unset=True))
    if result is None:
        raise HTTPException(status_code=404, detail="{{ entity.class_name }} not found")
    session.commit()
    return result


@router.delete("/{{ '{' }}{{ entity.name }}_id{{ '}' }}", status_code=204)
def delete_{{ entity.name }}({{ entity.name }}_id: {{ id_type }}, session: Session = Depends(get_session), _user=Depends({% if is_tenant_entity %}_require_admin{% else %}_require_auth{% endif %})):
    repo = SQLAlchemy{{ entity.class_name }}Repository(session)
    use_case = Delete{{ entity.class_name }}(repo)
    if not use_case({{ entity.name }}_id):
        raise HTTPException(status_code=404, detail="{{ entity.class_name }} not found")
    session.commit()
