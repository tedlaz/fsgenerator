from fastapi import APIRouter, Depends, HTTPException
from sqlalchemy.orm import Session

from application.dtos.{{ entity.name }} import (
    {{ entity.class_name }}Create,
    {{ entity.class_name }}Response,
    {{ entity.class_name }}Update,
)
from application.use_cases.{{ entity.name }} import (
    Create{{ entity.class_name }},
    Delete{{ entity.class_name }},
    Get{{ entity.class_name }},
    List{{ entity.class_name }}s,
    Update{{ entity.class_name }},
)
from domain.entities.{{ entity.name }} import {{ entity.class_name }}
from infrastructure.persistence.sqlalchemy.repositories.{{ entity.name }} import (
    SQLAlchemy{{ entity.class_name }}Repository,
)
from infrastructure.web.fastapi.dependencies import get_session

router = APIRouter(prefix="/{{ entity.name }}", tags=["{{ entity.name }}"])


@router.get("/", response_model=list[{{ entity.class_name }}Response])
def list_{{ entity.name }}s(session: Session = Depends(get_session)):
    repo = SQLAlchemy{{ entity.class_name }}Repository(session)
    use_case = List{{ entity.class_name }}s(repo)
    return use_case()


@router.get("/{{ '{' }}{{ entity.name }}_id{{ '}' }}", response_model={{ entity.class_name }}Response)
def get_{{ entity.name }}({{ entity.name }}_id: {{ id_type }}, session: Session = Depends(get_session)):
    repo = SQLAlchemy{{ entity.class_name }}Repository(session)
    use_case = Get{{ entity.class_name }}(repo)
    result = use_case({{ entity.name }}_id)
    if result is None:
        raise HTTPException(status_code=404, detail="{{ entity.class_name }} not found")
    return result


@router.post("/", response_model={{ entity.class_name }}Response, status_code=201)
def create_{{ entity.name }}(data: {{ entity.class_name }}Create, session: Session = Depends(get_session)):
    repo = SQLAlchemy{{ entity.class_name }}Repository(session)
    use_case = Create{{ entity.class_name }}(repo)
    entity = {{ entity.class_name }}(**data.model_dump())
    result = use_case(entity)
    session.commit()
    return result


@router.put("/{{ '{' }}{{ entity.name }}_id{{ '}' }}", response_model={{ entity.class_name }}Response)
def update_{{ entity.name }}({{ entity.name }}_id: {{ id_type }}, data: {{ entity.class_name }}Update, session: Session = Depends(get_session)):
    repo = SQLAlchemy{{ entity.class_name }}Repository(session)
    use_case = Update{{ entity.class_name }}(repo)
    result = use_case({{ entity.name }}_id, data.model_dump(exclude_unset=True))
    if result is None:
        raise HTTPException(status_code=404, detail="{{ entity.class_name }} not found")
    session.commit()
    return result


@router.delete("/{{ '{' }}{{ entity.name }}_id{{ '}' }}", status_code=204)
def delete_{{ entity.name }}({{ entity.name }}_id: {{ id_type }}, session: Session = Depends(get_session)):
    repo = SQLAlchemy{{ entity.class_name }}Repository(session)
    use_case = Delete{{ entity.class_name }}(repo)
    if not use_case({{ entity.name }}_id):
        raise HTTPException(status_code=404, detail="{{ entity.class_name }} not found")
    session.commit()
